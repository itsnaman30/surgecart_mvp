PORT=5000
CLIENT_ORIGIN=http://localhost:5173
JWT_SECRET=change-me-in-production
MONGO_URI=mongodb://localhost:27017/surgecart
IGNORE_ATLAS_ERRORS=true
USE_SQLITE=true

# Slot checking: browser (Playwright) with demand-heuristic fallback
USE_BROWSER_CHECKS=true
USE_API_SCRAPER=false

# Twilio SMS alerts (required for live texts)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_NUMBER=+1XXXXXXXXXX

# Optional API scraper tokens
BLINKIT_SESSION_TOKEN=
ZEPTO_AUTH_TOKEN=
